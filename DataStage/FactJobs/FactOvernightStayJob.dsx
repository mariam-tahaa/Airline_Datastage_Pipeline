</BFILEasBLOB><TreatWarningsAsErrors type=\\'bool\\'><![CDATA[0]]></TreatWarningsAsErrors><TreatFetchTruncateAsError type=\\'bool\\'><![CDATA[1]]></TreatFetchTruncateAsError></Session><BeforeAfter collapsed=\\'1\\' modified=\\'1\\' type=\\'bool\\'><![CDATA[0]]></BeforeAfter><ApplicationFailoverControl collapsed=\\'1\\' type=\\'bool\\'><![CDATA[0]]></ApplicationFailoverControl></Usage></Properties >'
-connector '{
   variant=\\'10\\', 
   library=ccora10g, 
   version=1.0, 
   variantlist=\\'V1;10:\"10g\":ccora10g;11:\"11g\":ccora11g\\', 
   versionlist=\\'1.0,1.0\\', 
   name=OracleConnector
}'
-source 0 '{
      DSIsKey={FULL_DATE=1}, 
      DSSQLType={DATE_KEY=3, FULL_DATE=12, DAY=3, MONTH=3, QUARTER=3, YEAR=3}, 
      DSSQLPrecision={DATE_KEY=8, FULL_DATE=30, DAY=2, MONTH=2, QUARTER=1, YEAR=4}, 
      DSNativeType={DATE_KEY=\\'NUMBER\\', FULL_DATE=\\'VARCHAR2\\', DAY=\\'NUMBER\\', MONTH=\\'NUMBER\\', QUARTER=\\'NUMBER\\', YEAR=\\'NUMBER\\'}, 
      DSSchema=\\'record
         (
           DATE_KEY\\:decimal\\[8\\,0\\]\\;
           FULL_DATE\\:ustring\\[max\\=30\\]\\;
           DAY\\:decimal\\[2\\,0\\]\\;
           MONTH\\:decimal\\[2\\,0\\]\\;
           QUARTER\\:decimal\\[1\\,0\\]\\;
           YEAR\\:decimal\\[4\\,0\\]\\;
         )\\'
}'
   

## General options
[ident('Oracle_Connector_58'); jobmon_ident('Oracle_Connector_58')]
## Outputs
0> [modify (
  DATE_KEY:not_nullable decimal[8,0]=DATE_KEY;
  FULL_DATE:not_nullable ustring[max=30]=FULL_DATE;
  DAY:not_nullable decimal[2,0]=DAY;
  MONTH:not_nullable decimal[2,0]=MONTH;
  QUARTER:not_nullable decimal[1,0]=QUARTER;
  YEAR:not_nullable decimal[4,0]=YEAR;
keep
  DATE_KEY,FULL_DATE,DAY,MONTH,
  QUARTER,YEAR;
)] 'Oracle_Connector_58:DSLink59.v'
;


