    dp.PASSENGER_KEY,
    dpr.PROMOTION_KEY,
    TO_CHAR(pr.SENT_DATE, \\'YYYYMMDD\\') AS DATE_KEY,
    4 AS CHANNEL_KEY,
    pr.RESPONSE_ID,
    pr.OPENED_FLAG,
    pr.CLICKED_FLAG,
    pr.BOOKED_FLAG
FROM MARKETING_RESPONSE pr
INNER JOIN DIMPASSENGER dp
    ON pr.PASSENGER_ID = dp.PASSENGER_ID
   AND dp.CURRENT_FLAG = \\'Y\\'
INNER JOIN DIM_PROMOTION dpr
    ON pr.PROMO_ID = dpr.PROMO_ID;]]><ReadFromFileSelect type=\\'bool\\'><![CDATA[0]]></ReadFromFileSelect><Tables collapsed=\\'1\\'><Table type=\\'string\\'><![CDATA[MARKETING_RESPONSE]]></Table><Table type=\\'string\\'><![CDATA[DIMPASSENGER]]></Table><Table type=\\'string\\'><![CDATA[DIM_PROMOTION]]></Table></Tables><Parameters collapsed=\\'1\\'></Parameters><Columns collapsed=\\'1\\'><Column type=\\'string\\'><![CDATA[BOOKED_FLAG,BOOKED_FLAG,MARKETING_RESPONSE]]></Column><Column type=\\'string\\'><![CDATA[CLICKED_FLAG,CLICKED_FLAG,MARKETING_RESPONSE]]></Column><Column type=\\'string\\'><![CDATA[OPENED_FLAG,OPENED_FLAG,MARKETING_RESPONSE]]></Column><Column type=\\'string\\'><![CDATA[RESPONSE_ID,RESPONSE_ID,MARKETING_RESPONSE]]></Column><Column type=\\'string\\'><![CDATA[CHANNEL_KEY,(null),MARKETING_RESPONSE]]></Column><Column type=\\'string\\'><![CDATA[DATE_KEY,SENT_DATE,MARKETING_RESPONSE]]></Column><Column type=\\'string\\'><![CDATA[PROMOTION_KEY,PROMOTION_KEY,DIM_PROMOTION]]></Column><Column type=\\'string\\'><![CDATA[PASSENGER_KEY,PASSENGER_KEY,DIMPASSENGER]]></Column></Columns></SelectStatement></SQL><EnablePartitionedReads collapsed=\\'1\\' type=\\'bool\\'><![CDATA[0]]></EnablePartitionedReads><Transaction><IsolationLevel type=\\'int\\'><![CDATA[0]]></IsolationLevel><RecordCount type=\\'int\\'><![CDATA[2000]]></RecordCount><EndOfWave type=\\'int\\'><![CDATA[0]]></EndOfWave></Transaction><Session><ArraySize type=\\'int\\'><![CDATA[2000]]></ArraySize><PrefetchRowCount type=\\'int\\'><![CDATA[1]]></PrefetchRowCount><PrefetchMemorySize type=\\'int\\'><![CDATA[0]]></PrefetchMemorySize><PassLobLocator collapsed=\\'1\\' type=\\'bool\\'><![CDATA[0]]></PassLobLocator><BFILEasBLOB type=\\'bool\\'><![CDATA[0]]></BFILEasBLOB><TreatWarningsAsErrors type=\\'bool\\'><![CDATA[0]]></TreatWarningsAsErrors><TreatFetchTruncateAsError type=\\'bool\\'><![CDATA[1]]></TreatFetchTruncateAsError></Session><BeforeAfter collapsed=\\'1\\' type=\\'bool\\'><![CDATA[0]]></BeforeAfter><Appl